# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Required for the copy-trading SEC EDGAR tool.
# Use a descriptive company/app name and contact email.
SEC_USER_AGENT=

# Alpaca Paper Trading
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Market Data
# Stocks feed options: iex, sip, delayed_sip
ALPACA_STOCK_FEED=iex

# WhatsApp trade notifications through Twilio
# Use E.164 numbers. Prefix is optional; the app adds whatsapp: when missing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=

# TradingView webhooks
# Use this to validate incoming TradingView alerts.
TRADINGVIEW_WEBHOOK_SECRET=
